generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Order {
  id                 String     @id @default(cuid())
  orderNumber        String     @unique
  customerName       String
  customerEmail      String
  customerPhone      String
  shippingAddress    String
  shippingCity       String
  shippingPostalCode String
  paymentMethod      String
  items              String
  subtotal           Float
  shippingCost       Float
  total              Float
  promoCode          String?
  discount           Float?
  status             String     @default("pending")
  affiliateCode      String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  customerId         String?
  affiliate          Affiliate? @relation(fields: [affiliateCode], references: [code])
  customer           Customer?  @relation(fields: [customerId], references: [id])
}

model Customer {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  name       String
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  address    String?
  city       String?
  postalCode String?
  wishlist   String   @default("[]")
  orders     Order[]
}

model Product {
  id                  Int      @id @default(autoincrement())
  slug                String   @unique
  name                String
  brandId             String   @default("valentino")
  brandLabel          String
  gender              String
  subcategory         String
  subcategoryLabel    String
  tagline             String
  price               Float
  originalPrice       Float?
  description         String
  longDescription     String
  images              String
  notes               String
  ingredients         String
  sizes               String
  bottleColor         String
  bottleColorLabel    String
  bottleMaterial      String
  bottleMaterialLabel String
  rating              Float    @default(0)
  reviewCount         Int      @default(0)
  releaseDate         String
  tags                String
  inStock             Boolean  @default(true)
  stock               Int      @default(10)
  perfectSeason       String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  testerPrice         Float?
  isTester            Boolean  @default(false)
  sku                 String?  @unique
  brand               Brand    @relation(fields: [brandId], references: [slug])
  reviews             Review[]
}

model Review {
  id          Int      @id @default(autoincrement())
  productSlug String
  author      String
  city        String
  rating      Int
  title       String
  comment     String
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  product     Product  @relation(fields: [productSlug], references: [slug])
}

model SiteConfig {
  id                  Int      @id @default(autoincrement())
  adminUsername       String   @default("admin")
  adminPassword       String   @default("nouamane2024")
  shippingFee         Float    @default(35)
  contactPhone        String   @default("+212 5 35 63 42 18")
  contactEmail        String   @default("contact@nouamane.ma")
  heroTitle           String   @default("L'Essence de l'Élégance")
  heroSubtitle        String   @default("Découvrez notre collection de parfums de luxe, conçue pour laisser une empreinte inoubliable.")
  instagramUrl        String?
  facebookUrl         String?
  tiktokUrl           String?
  whatsappUrl         String?
  updatedAt           DateTime @updatedAt
  featuredBestsellers String   @default("[]")
  featuredSeasonal    String   @default("[]")
  featuredLatest      String   @default("[]")
  coffretsCoverImage  String   @default("/images/category/pack-decouverte-luxe.jpg")
}

model NewsletterSubscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model LandingPage {
  id           String    @id @default(cuid())
  slug         String    @unique
  title        String
  subtitle     String
  heroImage    String
  deadline     DateTime?
  badgeText    String
  productSlugs String
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Visitor {
  id        String     @id @default(cuid())
  ipHash    String     @unique
  city      String?
  country   String?
  createdAt DateTime   @default(now())
  lastSeen  DateTime   @default(now())
  visits    PageView[]
}

model PageView {
  id        Int      @id @default(autoincrement())
  visitorId String
  pathname  String
  createdAt DateTime @default(now())
  visitor   Visitor  @relation(fields: [visitorId], references: [id])
}

model Brand {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  label       String
  description String
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String
  message   String
  status    String   @default("unread")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PromoCode {
  id        String   @id @default(cuid())
  code      String   @unique
  type      String
  value     Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id                  String   @id @default(cuid())
  slug                String   @unique
  title               String
  excerpt             String
  content             String
  coverImage          String
  author              String   @default("Nouamane")
  status              String   @default("draft")
  metaTitle           String?
  metaDescription     String?
  relatedProductSlugs String   @default("[]")
  publishedAt         DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  category            String   @default("Général")
  ctaLink             String?
  ctaText             String?
  tags                String   @default("[]")
}

model Affiliate {
  id               String   @id @default(cuid())
  name             String
  code             String   @unique
  commissionRate   Float    @default(10)
  visits           Int      @default(0)
  sales            Int      @default(0)
  revenueGenerated Float    @default(0)
  commissionEarned Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  orders           Order[]
}
